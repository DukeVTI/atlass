# ─── Telegram ────────────────────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=
ALLOWED_USER_IDS=                    # comma-separated Telegram user IDs (Duke's only)

# ─── Anthropic (Claude — sole LLM) ───────────────────────────────────────────
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-haiku-4-5-20251001
CLAUDE_MAX_TOKENS=2048
CLAUDE_TEMPERATURE=0.6

# ─── STT (Speech-to-Text) ────────────────────────────────────────────────────
GROQ_API_KEY=                            # Primary STT — get free key at console.groq.com
WHISPER_FALLBACK_MODEL=base              # Local fallback model size: tiny | base | small | medium

# ─── Proactive Alerts ─────────────────────────────────────────────────────────
URGENT_EMAIL_SCORE_THRESHOLD=60          # Alert threshold 0-100 (60 = recommended)
ALERT_VIP_EMAILS=                        # Comma-separated e.g. dana@client.com,samuel@co.com
ALERT_VIP_DOMAINS=paystack.com           # Comma-separated domains that always score high

# ─── Database ─────────────────────────────────────────────────────────────────
POSTGRES_PASSWORD=change_me_before_deploy
REDIS_PASSWORD=change_me_before_deploy

# ─── Web Search ───────────────────────────────────────────────────────────────
SERPAPI_KEY=

# ─── Paystack ─────────────────────────────────────────────────────────────────
PAYSTACK_SECRET_KEY=

# ─── Google APIs (OAuth token files — mount via Docker volume) ────────────────
# Generate credentials.json from Google Cloud Console (OAuth2 Client ID)
# Run OAuth flow locally once to produce token.json, then copy both to ./config/
GOOGLE_CLIENT_SECRETS_FILE=/app/config/credentials.json
GOOGLE_TOKEN_FILE=/app/config/token.json

# ─── PC Worker ────────────────────────────────────────────────────────────────
WORKER_TOKEN=change_me_before_deploy   # shared secret — same value on VPS and PC worker

# ─── Logging ──────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
