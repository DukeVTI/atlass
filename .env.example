# ─── Telegram ───────────────────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=
ALLOWED_USER_IDS=                    # comma-separated Telegram user IDs (Duke's only)

# ─── Anthropic (Claude Haiku 3 — sole LLM) ──────────────────────────────────
ANTHROPIC_API_KEY=

# ─── Database ────────────────────────────────────────────────────────────────
POSTGRES_PASSWORD=change_me_before_deploy
REDIS_PASSWORD=change_me_before_deploy   # used in prod only

# ─── Google APIs ─────────────────────────────────────────────────────────────
GOOGLE_CREDENTIALS_PATH=./config/credentials.json
GOOGLE_TOKEN_PATH=./config/token.json

# ─── GitHub ──────────────────────────────────────────────────────────────────
GITHUB_TOKEN=

# ─── Weather ─────────────────────────────────────────────────────────────────
OPENWEATHER_API_KEY=
DEFAULT_CITY=Ile-Ife

# ─── PC Worker ───────────────────────────────────────────────────────────────
PC_WORKER_SECRET=change_me_before_deploy   # shared secret for WebSocket auth

# ─── Logging ─────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
