# ─── Telegram ────────────────────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=
ALLOWED_USER_IDS=                    # comma-separated Telegram user IDs (Duke's only)

# ─── Anthropic (Claude — sole LLM) ───────────────────────────────────────────
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-3-5-haiku-20241022
CLAUDE_MAX_TOKENS=700
CLAUDE_TEMPERATURE=0.6

# ─── Database ─────────────────────────────────────────────────────────────────
POSTGRES_PASSWORD=change_me_before_deploy
REDIS_PASSWORD=change_me_before_deploy

# ─── Web Search ───────────────────────────────────────────────────────────────
SERPAPI_KEY=

# ─── Paystack ─────────────────────────────────────────────────────────────────
PAYSTACK_SECRET_KEY=

# ─── Google APIs (OAuth token files — mount via Docker volume) ────────────────
# Generate credentials.json from Google Cloud Console (OAuth2 Client ID)
# Run OAuth flow locally once to produce token.json, then copy both to ./config/
GOOGLE_CLIENT_SECRETS_FILE=/app/config/credentials.json
GOOGLE_TOKEN_FILE=/app/config/token.json

# ─── PC Worker ────────────────────────────────────────────────────────────────
WORKER_TOKEN=change_me_before_deploy   # shared secret — same value on VPS and PC worker

# ─── Logging ──────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
